// Orderin — Prisma Schema (SQLite)
// Converted from supabase/schema.sql

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Settings {
  id           String   @id @default(cuid())
  nama_cafe    String   @default("Orderin Cafe")
  logo_url     String?
  primaryColor String   @default("#10B981") @map("primary_color")
  theme        String   @default("dark")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("settings")
}

model Category {
  id        String   @id @default(cuid())
  nama      String
  urutan    Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")

  menus Menu[]

  @@map("categories")
}

model Menu {
  id           String   @id @default(cuid())
  categoryId   String?  @map("category_id")
  nama         String
  deskripsi    String?
  harga        Int      @default(0)
  foto_url     String?
  is_available Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  category   Category?   @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  orderItems OrderItem[]

  @@map("menus")
}

model Table {
  id         String   @id @default(cuid())
  nomor_meja String   @unique
  lokasi     String   @default("Lantai 1")
  status     String   @default("available")
  qr_code_url String?
  createdAt  DateTime @default(now()) @map("created_at")

  orders Order[]

  @@map("tables")
}

model Profile {
  id        String   @id @default(cuid())
  nama      String
  pin       String?  @unique
  role      String   @default("kasir")
  is_active Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")

  shifts         Shift[]
  confirmedOrders Order[] @relation("ConfirmedBy")

  @@map("profiles")
}

model Shift {
  id            String    @id @default(cuid())
  kasirId       String?   @map("kasir_id")
  clock_in      DateTime  @default(now())
  clock_out     DateTime?
  total_order   Int       @default(0)
  total_revenue Int       @default(0)
  createdAt     DateTime  @default(now()) @map("created_at")

  kasir  Profile? @relation(fields: [kasirId], references: [id], onDelete: SetNull)
  orders Order[]

  @@map("shifts")
}

model Order {
  id              String    @id @default(cuid())
  tableId         String?   @map("table_id")
  shiftId         String?   @map("shift_id")
  customer_name   String?
  status          String    @default("ordered")
  payment_method  String?
  bukti_bayar_url String?
  confirmedBy     String?   @map("confirmed_by")
  total           Int       @default(0)
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  table      Table?      @relation(fields: [tableId], references: [id], onDelete: SetNull)
  shift      Shift?      @relation(fields: [shiftId], references: [id], onDelete: SetNull)
  confirmer  Profile?    @relation("ConfirmedBy", fields: [confirmedBy], references: [id], onDelete: SetNull)
  orderItems OrderItem[]

  @@map("orders")
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String   @map("order_id")
  menuId    String?  @map("menu_id")
  nama_menu String
  harga     Int
  qty       Int      @default(1)
  subtotal  Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menu  Menu? @relation(fields: [menuId], references: [id], onDelete: SetNull)

  @@map("order_items")
}
